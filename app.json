{
  "expo": {
    "name": "ComercioApp",
    "slug": "comercioapp",
    "version": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "239481a4-15ea-481c-b4f0-176fdebc706d"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.yourprogrammer.comercioapp"
    },
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Para escanear códigos de barras y tomar fotos de productos",
        "NSPhotoLibraryUsageDescription": "Para guardar fotos de productos"
      }
    },
    "plugins": [
      "expo-camera",
      "expo-barcode-scanner",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "239481a4-15ea-481c-b4f0-176fdebc706d"
      }
    }
  }
}
